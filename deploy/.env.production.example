# ECS 本地构建的镜像名称与版本。部署脚本会用目标版本标签覆盖 IMAGE_TAG。
BACKEND_IMAGE=newblog-backend
FRONTEND_IMAGE=newblog-frontend
IMAGE_TAG=v0.0.0

# MySQL 只运行在 Docker 内部网络，不暴露到公网。
MYSQL_DATABASE=newblog
MYSQL_USER=newblog
MYSQL_PASSWORD=CHANGE_ME_TO_A_STRONG_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_TO_A_DIFFERENT_STRONG_ROOT_PASSWORD

# 应用密钥。不要把真实值提交到仓库。
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
INITIAL_ADMIN_USERNAME=CHANGE_ME_TO_YOUR_ADMIN_USERNAME
INITIAL_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_ADMIN_PASSWORD

# 对外统一使用 HTTPS 域名；容器之间的服务端请求由 Compose 固定走 backend:8080。
SITE_URL=https://www.spring0w04j.top
NEXT_PUBLIC_API_BASE_URL=https://www.spring0w04j.top
PUBLIC_BASE_URL=https://www.spring0w04j.top
CORS_ALLOWED_ORIGINS=https://www.spring0w04j.top

# 仅绑定到服务器 loopback，Nginx 再对外提供 HTTPS。
FRONTEND_PORT=3000
BACKEND_PORT=8080
